# 开发环境配置
# API基础URL会自动设置为 http://localhost:8080
VITE_APP_TITLE = MyObj网盘系统
VITE_APP_VERSION = 1.0.0

# API基础URL配置
VITE_APP_BASE_URL = http://127.0.0.1:8080
# 构建路径配置
VITE_APP_BASE_PATH = /
# API基础路径配置
VITE_APP_BASE_API = /dev-api
# 端口配置
VITE_APP_PORT = 5173

# 开发环境通常不需要压缩
# VITE_BUILD_COMPRESS=

# 开发环境：显示所有调试信息
VITE_LOG_LEVEL = debug
VITE_LOG_ENABLE = true
VITE_LOG_ENABLE_TIMESTAMP = true
VITE_LOG_ENABLE_CALLER = true

# ---- AI / OpenAI Compatible API ----
VITE_AI_API_URL = https://api.deepseek.com
VITE_AI_API_KEY = sk-b08ec6abaffb4059b4e4dc75124bf3c0
VITE_AI_MODEL = deepseek-v4-flash
VITE_AI_SYSTEM_PROMPT = 你是 MyObj 网盘的智能助手，可以帮助用户管理文件、分析存储、搜索内容。请用简洁专业的中文回复。
