# 生产环境配置
# 生产环境API URL会从当前域名或meta标签读取
VITE_APP_TITLE = MyObj网盘系统
VITE_APP_VERSION = 1.0.0

# API基础URL配置
VITE_APP_BASE_URL = http://localhost:8080
# 构建路径配置
VITE_APP_BASE_PATH = /
# API基础路径配置（生产环境直接使用 /api，与后端同端口）
VITE_APP_BASE_API = /prod-api
# 端口配置
VITE_APP_PORT = 5173

# 构建压缩配置
# 可选值: gzip, brotli
# 可以同时使用: gzip,brotli
# 留空则不启用压缩
VITE_BUILD_COMPRESS = gzip

# 生产环境：只显示错误，或完全关闭日志
VITE_LOG_LEVEL = error
VITE_LOG_ENABLE = true
# 或者完全关闭日志
# VITE_LOG_ENABLE=false
VITE_LOG_ENABLE_TIMESTAMP = true
VITE_LOG_ENABLE_CALLER = false

# ---- AI / OpenAI Compatible API ----
VITE_AI_API_URL = https://api.openai.com
VITE_AI_API_KEY = 
VITE_AI_MODEL = gpt-3.5-turbo
VITE_AI_SYSTEM_PROMPT = 你是 MyObj 网盘的智能助手，可以帮助用户管理文件、分析存储、搜索内容。请用简洁专业的中文回复。
