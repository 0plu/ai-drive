create table public.attendance_records (
  id bigint generated by default as identity not null,
  meeting_id bigint not null,
  student_id bigint not null,
  status text not null default 'absent'::text,
  checkin_time timestamp with time zone null,
  created_at timestamp with time zone null default now(),
  constraint attendance_records_pkey primary key (id),
  constraint attendance_records_meeting_id_student_id_key unique (meeting_id, student_id),
  constraint attendance_records_meeting_id_fkey foreign KEY (meeting_id) references meeting_records (id) on delete CASCADE,
  constraint attendance_records_student_id_fkey foreign KEY (student_id) references students (id) on delete CASCADE
) TABLESPACE pg_default;


create table public.meeting_attendees (
  id bigint generated by default as identity not null,
  meeting_id bigint not null,
  student_id bigint not null,
  created_at timestamp with time zone not null default now(),
  constraint meeting_attendees_pkey primary key (id),
  constraint unique_meeting_student unique (meeting_id, student_id),
  constraint meeting_attendees_meeting_id_fkey foreign KEY (meeting_id) references meeting_records (id) on delete CASCADE,
  constraint meeting_attendees_student_id_fkey foreign KEY (student_id) references students (id) on delete CASCADE
) TABLESPACE pg_default;


create table public.meeting_photos (
  id bigint generated by default as identity not null,
  meeting_id bigint not null,
  url text not null,
  created_at timestamp with time zone null default now(),
  constraint meeting_photos_pkey primary key (id),
  constraint meeting_photos_meeting_id_fkey foreign KEY (meeting_id) references meeting_records (id) on delete CASCADE
) TABLESPACE pg_default;


create table public.meeting_records (
  id bigint generated by default as identity not null,
  title text not null,
  meeting_time timestamp with time zone not null,
  location text not null,
  content text not null,
  created_at timestamp with time zone not null default now(),
  advisor_id uuid null,
  constraint meeting_records_pkey primary key (id)
) TABLESPACE pg_default;


create table public.profiles (
  id uuid not null,
  name text null,
  phone text null,
  avatar_url text null,
  created_at timestamp with time zone null default now(),
  role text null default 'teacher'::text,
  email text null,
  real_name text null,
  constraint profiles_pkey primary key (id),
  constraint profiles_id_fkey foreign KEY (id) references auth.users (id) on delete CASCADE
) TABLESPACE pg_default;


create table public.students (
  id bigint generated by default as identity not null,
  name text not null,
  student_id text null,
  class_name text null,
  is_focused boolean null default false,
  gpa numeric(4, 2) null,
  created_at timestamp without time zone null default now(),
  remarks text null,
  talk_records jsonb null default '[]'::jsonb,
  awards jsonb null default '[]'::jsonb,
  special_cases jsonb null default '[]'::jsonb,
  phone text null,
  email text null,
  user_id uuid null,
  advisor_id uuid null,
  constraint students_pkey primary key (id),
  constraint students_student_id_key unique (student_id),
  constraint students_advisor_id_fkey foreign KEY (advisor_id) references auth.users (id) on delete set null,
  constraint students_user_id_fkey foreign KEY (user_id) references auth.users (id) on delete CASCADE
) TABLESPACE pg_default;


create table public.warning_rules (
  id bigint generated by default as identity not null,
  gpa_threshold numeric(3, 2) not null default 2.0,
  created_at timestamp with time zone null default now(),
  updated_at timestamp with time zone null default now(),
  user_id uuid null,
  constraint warning_rules_pkey primary key (id),
  constraint warning_rules_user_id_fkey foreign KEY (user_id) references auth.users (id) on delete CASCADE
) TABLESPACE pg_default;

create unique INDEX IF not exists idx_warning_rules_user_id on public.warning_rules using btree (user_id) TABLESPACE pg_default;